#!/usr/bin/env bash
# Mock for the gh CLI. Controlled by env vars:
#   MOCK_LOGIN       GitHub login to return (default: testuser)
#   MOCK_PR_NUMBER   PR number to return from pr list (default: 42)
#   MOCK_PR_JSON     Path to fixture file for pr view (required for pr view calls)

args="$*"

if [[ "$args" == *"api user"* ]]; then
    printf '%s\n' "${MOCK_LOGIN:-testuser}"
elif [[ "$args" == *"pr list"* ]]; then
    printf '%s\n' "${MOCK_PR_NUMBER:-42}"
elif [[ "$args" == *"pr view"* ]]; then
    sed \
        -e "s/%%HEAD_SHA%%/${MOCK_HEAD_SHA:-0000000000000000000000000000000000000000}/g" \
        -e "s/%%ACK_SHA%%/${MOCK_ACK_SHA:-}/g" \
        -e "s/%%LOGIN%%/${MOCK_LOGIN:-testuser}/g" \
        "${MOCK_PR_JSON:?MOCK_PR_JSON not set}"
else
    printf 'mock_gh: unhandled args: %s\n' "$args" >&2
    exit 1
fi
