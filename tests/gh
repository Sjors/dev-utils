#!/usr/bin/env bash
# Mock for the gh CLI. Controlled by env vars:
#   MOCK_LOGIN       GitHub login to return (default: testuser)
#   MOCK_PR_NUMBER   PR number to return from pr list (default: 42)
#   MOCK_PR_JSON     Path to fixture file for pr view (required for pr view calls)
#   MOCK_BASE_PR     PR number used as the explicit stacked base
#   MOCK_BASE_HEAD   headRefOid returned for MOCK_BASE_PR
#   MOCK_BASE_COUNT  commit count returned for MOCK_BASE_PR
#   MOCK_OPEN_BRANCHES space-separated branch names treated as open PRs

args="$*"

if [[ "$args" == *"api user"* ]]; then
    printf '%s\n' "${MOCK_LOGIN:-testuser}"
elif [[ "$args" == *"pr list"* ]]; then
    if [[ -n "${MOCK_OPEN_BRANCHES:-}" ]]; then
        branch=""
        if [[ "$args" == *"--search head:"* ]]; then
            branch="${args##*--search head:}"
            branch="${branch%% *}"
        elif [[ "$args" == *"--head "* ]]; then
            branch="${args##*--head }"
            branch="${branch%% *}"
        fi

        if [[ -n "$branch" ]]; then
            for open_branch in ${MOCK_OPEN_BRANCHES}; do
                if [[ "$open_branch" == "$branch" ]]; then
                    printf '%s\n' "${MOCK_PR_NUMBER:-42}"
                    exit 0
                fi
            done
            printf '\n'
            exit 0
        fi
    fi
    printf '%s\n' "${MOCK_PR_NUMBER:-42}"
elif [[ "$args" == *"pr view"* ]]; then
    if [[ -n "${MOCK_BASE_PR:-}" && "$args" == *"pr view ${MOCK_BASE_PR} "* ]]; then
        if [[ "$args" == *"--jq .headRefOid // empty"* ]]; then
            printf '%s\n' "${MOCK_BASE_HEAD:?MOCK_BASE_HEAD not set}"
        elif [[ "$args" == *"@tsv"* ]]; then
            printf '%s\t%s\n' \
                "${MOCK_BASE_HEAD:?MOCK_BASE_HEAD not set}" \
                "${MOCK_BASE_COUNT:?MOCK_BASE_COUNT not set}"
        else
            printf '{"headRefOid":"%s","commits":[%s]}\n' \
                "${MOCK_BASE_HEAD:?MOCK_BASE_HEAD not set}" \
                "$(yes '{}' | head -n "${MOCK_BASE_COUNT:-1}" | paste -sd, -)"
        fi
    else
        sed \
            -e "s/%%HEAD_SHA%%/${MOCK_HEAD_SHA:-0000000000000000000000000000000000000000}/g" \
            -e "s/%%ACK_SHA%%/${MOCK_ACK_SHA:-}/g" \
            -e "s/%%LOGIN%%/${MOCK_LOGIN:-testuser}/g" \
            "${MOCK_PR_JSON:?MOCK_PR_JSON not set}"
    fi
else
    printf 'mock_gh: unhandled args: %s\n' "$args" >&2
    exit 1
fi
