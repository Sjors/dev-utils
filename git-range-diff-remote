#!/usr/bin/env bash
# To regenerate the man page after editing the usage() text:
#   help2man git-range-diff-remote --no-info \
#     --name "range-diff local commits against a PR's remote state" \
#     -o share/man/man1/git-range-diff-remote.1
set -euo pipefail

die() {
    printf '%s\n' "$*" >&2
    exit 1
}

lower() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

run_gh() {
    if "$debug"; then
        printf 'DEBUG gh' >&2
        local arg
        for arg in "$@"; do
            printf ' %q' "$arg" >&2
        done
        printf '\n' >&2
    fi
    gh "$@"
}

ensure_gh_login() {
    if [[ -z "$_gh_login" ]]; then
        _gh_login="$(run_gh api user --jq .login)" || return 1
    fi
}

_inferred_tracking=""  # set by ensure_branch_context when detached but inferable
_current_pr_number=""
_current_pr_json=""
_gh_login=""
_repo_owner=""
_repo_full_name=""
_explicit_top_base=""
_explicit_top_count=""
_top_base_commit=""
explicit_pr_number=""
debug=false

usage() {
    cat <<'EOF'
Usage: git range-diff-remote [OPTION]... [RANGE-DIFF-OPTION]...

Compare local commits against the remote version of the current pull request
using git-range-diff(1).

In the default mode the "old" side is the pushed remote ref (@{push}) and the
"new" side is local HEAD. Useful for reviewing local changes before pushing.
PR discovery first uses the current gh repository context and then falls back
to the pushed remote's owner/repo. Base branches are resolved from the pushed
remote before falling back to origin.

With --since-ack the "old" side is the commit you last ACK'd (or utACK'd) in a
PR comment. Useful when re-reviewing a PR after a force-push.

With --since HASH the "old" side is the specified commit. Like --since-ack but
without the GitHub lookup — useful when you know the commit hash already.

With --top, only compare commits that are on top of a stacked base branch. The
base is inferred as the nearest ancestor of HEAD that is also the tip of
another non-main branch/ref.

Options:
      --since-ack   range-diff from last ACK'd commit instead of @{push}
      --since HASH  range-diff from the specified commit instead of @{push}
      --pr NUMBER   use the specified pull request instead of inferring by head branch
      --top         only compare commits that are not in the inferred base PR
      --debug       print gh commands before running them
  -h, --help        display this help and exit
      --version     output version information and exit

Pass git-range-diff(1) options after `--` (e.g. `git range-diff-remote --
--creation-factor=95 --no-color`). Unknown top-level options are rejected.

Requirements: git, gh, jq
EOF
}

ensure_branch_context() {
    local current_branch
    current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    [[ -n "$current_branch" ]] && return 0

    local -a remote_refs
    mapfile -t remote_refs < <(
        git for-each-ref --format='%(refname:short)' --points-at HEAD refs/remotes \
        | grep -v '/HEAD$' || true
    )

    if (( ${#remote_refs[@]} == 0 )); then
        die "Detached HEAD; check out a branch and rerun"
    elif "$since_ack"; then
        local ref remote branch normalized candidate preferred=""
        local -a normalized_refs=()

        for ref in "${remote_refs[@]}"; do
            remote="${ref%%/*}"
            branch="${ref#*/}"
            normalized="$branch"
            if [[ "$branch" =~ ^(.+)\.[0-9]+-rebase$ ]]; then
                normalized="${BASH_REMATCH[1]}"
            fi
            candidate="$remote/$normalized"
            if [[ "$candidate" == "$ref" ]]; then
                continue
            fi
            normalized_refs+=("$candidate")
        done

        if (( ${#normalized_refs[@]} > 0 )); then
            local normalized_ref
            for normalized_ref in "${normalized_refs[@]}"; do
                for ref in "${remote_refs[@]}"; do
                    [[ "$ref" == "$normalized_ref" ]] || continue
                    if [[ -n "$preferred" && "$preferred" != "$normalized_ref" ]]; then
                        preferred=""
                        break 2
                    fi
                    preferred="$normalized_ref"
                done
            done

            if [[ -n "$preferred" ]]; then
                _inferred_tracking="$preferred"
                return 0
            fi
        fi
    elif (( ${#remote_refs[@]} > 1 )); then
        local msg="Detached HEAD; did you mean to check out one of these?"$'\n'
        local ref
        for ref in "${remote_refs[@]}"; do
            msg+="  git checkout ${ref#*/}"$'\n'
        done
        die "${msg%$'\n'}"
    fi

    # Exactly one remote ref — infer tracking from it (used by --since-ack)
    _inferred_tracking="${remote_refs[0]}"
}

list_matching_pr_numbers() {
    local owner="$1" branch="$2" repo="${3:-}"
    local owner_lc
    local -a repo_args=()

    owner_lc="$(lower "$owner")"
    [[ -n "$repo" ]] && repo_args=(--repo "$repo")
    run_gh pr list "${repo_args[@]}" --state open --search "head:$branch" \
        --json number,headRefName,headRepositoryOwner \
        --jq ".[] | select((.headRefName | ascii_downcase) == (\"$branch\" | ascii_downcase) and (.headRepositoryOwner.login | ascii_downcase) == (\"$owner_lc\")) | .number"
}

pr_metadata_matches() {
    local json="$1" owner="$2" branch="$3"
    local json_owner json_branch

    json_owner="$(printf '%s\n' "$json" | jq -r '.headRepositoryOwner.login // empty')"
    json_branch="$(printf '%s\n' "$json" | jq -r '.headRefName // empty')"
    [[ -n "$json_owner" && -n "$json_branch" ]] || return 1
    [[ "$(lower "$json_owner")" == "$(lower "$owner")" && "$(lower "$json_branch")" == "$(lower "$branch")" ]]
}

view_resolved_pr() {
    local number="$1"
    shift

    if [[ -n "${pr_repo:-}" ]]; then
        run_gh pr view "$number" --repo "$pr_repo" "$@"
    else
        run_gh pr view "$number" "$@"
    fi
}

try_view_pr_metadata() {
    local number="$1" repo="${2:-}"
    local -a repo_args=()

    [[ -n "$repo" ]] && repo_args=(--repo "$repo")
    if "$debug"; then
        run_gh pr view "$number" "${repo_args[@]}" --json number,headRefName,headRepositoryOwner
    else
        run_gh pr view "$number" "${repo_args[@]}" --json number,headRefName,headRepositoryOwner 2>/dev/null
    fi
}

# Find the PR number for a given remote owner and branch name.
# Sets the global variables: pr_number, pr_repo
resolve_pr() {
    local owner="$1" branch="$2" repo="${3:-}"
    local pr_numbers_raw
    local -a pr_numbers

    pr_repo=""
    ensure_gh_login || die "Failed to determine GitHub login via gh"
    login="$_gh_login"

    if [[ -n "$explicit_pr_number" ]]; then
        local explicit_json=""

        if explicit_json="$(try_view_pr_metadata "$explicit_pr_number")" \
            && pr_metadata_matches "$explicit_json" "$owner" "$branch"; then
            pr_number="$explicit_pr_number"
            return 0
        fi
        if [[ -n "$repo" ]] \
            && explicit_json="$(try_view_pr_metadata "$explicit_pr_number" "$repo")" \
            && pr_metadata_matches "$explicit_json" "$owner" "$branch"; then
            pr_number="$explicit_pr_number"
            pr_repo="$repo"
            return 0
        fi
        [[ -n "$explicit_json" ]] || die "Failed to read PR #$explicit_pr_number"
        die "PR #$explicit_pr_number does not match head branch $owner:$branch"
    fi

    pr_numbers_raw="$(list_matching_pr_numbers "$owner" "$branch")" \
        || die "Failed to resolve PR via gh"
    mapfile -t pr_numbers < <(printf '%s\n' "$pr_numbers_raw" | sed '/^$/d' | sort -n)
    if (( ${#pr_numbers[@]} == 0 )) && [[ -n "$repo" ]]; then
        pr_numbers_raw="$(list_matching_pr_numbers "$owner" "$branch" "$repo")" \
            || die "Failed to resolve PR via gh"
        mapfile -t pr_numbers < <(printf '%s\n' "$pr_numbers_raw" | sed '/^$/d' | sort -n)
        (( ${#pr_numbers[@]} == 0 )) || pr_repo="$repo"
    fi

    if (( ${#pr_numbers[@]} == 0 )); then
        die "No open PR found for $owner:$branch"
    fi
    if (( ${#pr_numbers[@]} > 1 )); then
        local msg="Ambiguous pull request for $owner:$branch; please specify"
        local i
        for i in "${!pr_numbers[@]}"; do
            if (( i == 0 )); then
                msg+=" --pr ${pr_numbers[i]}"
            else
                msg+=" or --pr ${pr_numbers[i]}"
            fi
        done
        die "$msg"
    fi

    pr_number="${pr_numbers[0]}"
    [[ -n "$pr_number" ]] || die "No open PR found for $owner:$branch"
}

load_current_pr_json() {
    [[ -n "$_current_pr_json" ]] && return 0

    local remote_ref remote owner branch url repo

    remote_ref="$(git rev-parse --symbolic-full-name @{push} 2>/dev/null || true)"
    if [[ -z "$remote_ref" ]]; then
        remote_ref="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true)"
    fi
    if [[ -z "$remote_ref" && -n "$_inferred_tracking" ]]; then
        remote_ref="refs/remotes/$_inferred_tracking"
    fi
    [[ -n "$remote_ref" ]] || return 1

    if [[ "$remote_ref" == refs/remotes/* ]]; then
        remote="${remote_ref#refs/remotes/}"
        branch="${remote#*/}"
        remote="${remote%%/*}"
    else
        remote="$remote_ref"
        branch="${remote_ref#*/}"
    fi
    remote="${remote%%/*}"

    url="$(git remote get-url --push "$remote" 2>/dev/null || git remote get-url "$remote" 2>/dev/null)" || return 1
    owner="$(owner_from_url "$url")" || return 1
    repo="$(repo_full_name_from_url "$url")" || return 1

    resolve_pr "$owner" "$branch" "$repo"
    _current_pr_number="$pr_number"
    _current_pr_json="$(view_resolved_pr "$pr_number" --json body,commits,baseRefName,headRefOid,headRefName,headRepositoryOwner,comments,reviews)" \
        || die "Failed to read PR metadata"
}

ensure_current_repo_owner() {
    if [[ -n "$_repo_owner" ]]; then
        return 0
    fi

    local remote_ref remote url

    remote_ref="$(git rev-parse --symbolic-full-name @{push} 2>/dev/null || true)"
    if [[ -z "$remote_ref" ]]; then
        remote_ref="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true)"
    fi
    if [[ -z "$remote_ref" && -n "$_inferred_tracking" ]]; then
        remote_ref="refs/remotes/$_inferred_tracking"
    fi
    [[ -n "$remote_ref" ]] || return 1

    if [[ "$remote_ref" == refs/remotes/* ]]; then
        remote="${remote_ref#refs/remotes/}"
    else
        remote="$remote_ref"
    fi
    remote="${remote%%/*}"

    url="$(git remote get-url --push "$remote" 2>/dev/null || git remote get-url "$remote" 2>/dev/null)" || return 1
    _repo_full_name="$(repo_full_name_from_url "$url")" || return 1
    _repo_owner="${_repo_full_name%%/*}"
}

find_open_pr_number() {
    local owner="$1" branch="$2" repo="${3:-}"
    local pr_num

    ensure_gh_login || return 1
    login="$_gh_login"
    pr_num="$(list_matching_pr_numbers "$owner" "$branch" 2>/dev/null | head -n1 || true)"
    if [[ -z "$pr_num" && -n "$repo" ]]; then
        pr_num="$(list_matching_pr_numbers "$owner" "$branch" "$repo" 2>/dev/null | head -n1 || true)"
    fi
    [[ -n "$pr_num" ]] && printf '%s\n' "$pr_num"
}

ref_has_open_pr() {
    local refname="$1"
    local owner branch remote repo pr_num

    case "$refname" in
        refs/heads/*)
            ensure_current_repo_owner || return 1
            owner="$_repo_owner"
            repo="$_repo_full_name"
            branch="${refname#refs/heads/}"
            ;;
        refs/remotes/*)
            remote="${refname#refs/remotes/}"
            branch="${remote#*/}"
            remote="${remote%%/*}"
            [[ "$branch" == "HEAD" ]] && return 1
            repo="$(git remote get-url --push "$remote" 2>/dev/null || git remote get-url "$remote" 2>/dev/null)" || return 1
            repo="$(repo_full_name_from_url "$repo")" || return 1
            owner="${repo%%/*}"
            ;;
        *)
            return 1
            ;;
    esac

    if "$debug"; then
        printf 'DEBUG candidate ref=%s owner=%s branch=%s\n' "$refname" "$owner" "$branch" >&2
    fi
    pr_num="$(find_open_pr_number "$owner" "$branch" "$repo")"
    [[ -n "$pr_num" ]]
}

base_ref_for_branch() {
    local base_branch="$1" preferred_remote="${2:-}"
    local candidate ref found=""

    if [[ -n "$preferred_remote" ]]; then
        candidate="${preferred_remote}/${base_branch}"
        if git rev-parse --verify --quiet "$candidate^{commit}" >/dev/null; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    candidate="origin/${base_branch}"
    if git rev-parse --verify --quiet "$candidate^{commit}" >/dev/null; then
        printf '%s\n' "$candidate"
        return 0
    fi

    while read -r ref; do
        [[ -n "$ref" ]] || continue
        if [[ -n "$found" && "$found" != "$ref" ]]; then
            return 1
        fi
        found="$ref"
    done < <(git for-each-ref --format='%(refname:short)' "refs/remotes/*/${base_branch}")

    [[ -n "$found" ]] || return 1
    printf '%s\n' "$found"
}

top_range_base_ref() {
    local base_branch="" remote_ref remote candidate

    load_current_pr_json || return 1
    base_branch="$(printf '%s\n' "$_current_pr_json" | jq -r '.baseRefName // empty')"
    [[ -n "$base_branch" ]] || return 1

    remote_ref="$(git rev-parse --symbolic-full-name @{push} 2>/dev/null || true)"
    if [[ -n "$remote_ref" && "$remote_ref" == refs/remotes/* ]]; then
        remote="${remote_ref#refs/remotes/}"
        remote="${remote%%/*}"
    fi
    candidate="$(base_ref_for_branch "$base_branch" "$remote" 2>/dev/null || true)"
    if [[ -n "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    return 1
}

explicit_top_base_commit() {
    local body base_pr base_head current_count base_count

    if [[ -n "$_explicit_top_base" ]]; then
        printf '%s\n' "$_explicit_top_base"
        return 0
    fi

    load_current_pr_json || return 1
    body="$(printf '%s\n' "$_current_pr_json" | jq -r '.body // empty')"
    [[ -n "$body" ]] || return 1

    base_pr="$(
        printf '%s\n' "$body" | awk '
            BEGIN { in_based_on = 0 }
            tolower($0) ~ /^[[:space:]]*based on:[[:space:]]*$/ {
                in_based_on = 1
                next
            }
            in_based_on {
                if ($0 ~ /^[[:space:]]*$/) exit
                if (match($0, /#[0-9]+/)) {
                    print substr($0, RSTART + 1, RLENGTH - 1)
                    exit
                }
            }
            !in_based_on && match(tolower($0), /based on:[[:space:]]*(bitcoin\/bitcoin)?#[0-9]+/) {
                s = substr($0, RSTART, RLENGTH)
                if (match(s, /#[0-9]+/)) {
                    print substr(s, RSTART + 1, RLENGTH - 1)
                    exit
                }
            }
        '
    )"
    [[ -n "$base_pr" ]] || return 1

    base_head="$(view_resolved_pr "$base_pr" --json headRefOid,commits --jq '[.headRefOid // empty, (.commits | length)] | @tsv')" \
        || die "Failed to read base PR #$base_pr"
    base_count="${base_head#*$'\t'}"
    base_head="${base_head%%$'\t'*}"
    [[ -n "$base_head" ]] || die "Base PR #$base_pr does not have a head commit"

    current_count="$(printf '%s\n' "$_current_pr_json" | jq -r '.commits | length')"
    [[ "$current_count" =~ ^[0-9]+$ ]] || die "Invalid current PR commit count: $current_count"
    [[ "$base_count" =~ ^[0-9]+$ ]] || die "Invalid base PR commit count: $base_count"
    (( current_count > base_count )) || die "Base PR #$base_pr is not smaller than current PR"
    _explicit_top_count="$((current_count - base_count))"
    _explicit_top_base="$base_head"

    if git merge-base --is-ancestor "$_explicit_top_base" HEAD; then
        printf '%s\n' "$_explicit_top_base"
        return 0
    fi

    die "Base PR #$base_pr head $_explicit_top_base is not an ancestor of HEAD"
}

# Extract GitHub owner/repository from a remote URL.
repo_full_name_from_url() {
    local url="$1"
    printf '%s\n' "$url" | sed -E 's#^[^:]+://[^/]+/##; s#^[^@]+@[^:]+:##; s#\.git$##'
}

# Extract GitHub owner from a remote URL.
owner_from_url() {
    local url="$1"
    repo_full_name_from_url "$url" | sed -E 's#^([^/]+)/.*#\1#'
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

since_ack=false
since_hash=""
top_only=false
debug=false
range_diff_args=()

while (( $# > 0 )); do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --version) printf 'git-range-diff-remote\n'; exit 0 ;;
        --since-ack) since_ack=true; shift ;;
        --since) shift; [[ $# -gt 0 ]] || die "--since requires a commit hash argument"; since_hash="$1"; shift ;;
        --since=*) since_hash="${1#--since=}"; shift ;;
        --pr) shift; [[ $# -gt 0 ]] || die "--pr requires a pull request number"; explicit_pr_number="$1"; shift ;;
        --pr=*) explicit_pr_number="${1#--pr=}"; shift ;;
        --top) top_only=true; shift ;;
        --debug) debug=true; shift ;;
        --) shift; range_diff_args+=("$@"); break ;;
        -*) die "Unknown option: $1"$'\n'"Pass git-range-diff options after --" ;;
        *) die "Unknown argument: $1" ;;
    esac
done

"$since_ack" && [[ -n "$since_hash" ]] && die "--since-ack and --since are mutually exclusive"
[[ -z "$explicit_pr_number" || "$explicit_pr_number" =~ ^[0-9]+$ ]] || die "--pr requires a numeric pull request number"

command -v git >/dev/null || die "git is required"
command -v gh  >/dev/null || die "gh is required"
command -v jq  >/dev/null || die "jq is required"

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Not inside a git repository"
ensure_branch_context

# ---------------------------------------------------------------------------
# Run range-diff from a known $prev commit to HEAD.
# Fetches $prev from $fetch_remote if not available locally (empty = skip fetch).
# ---------------------------------------------------------------------------
run_from_prev() {
    local prev="$1" n="${2:-}" fetch_remote="${3:-}"

    if ! git rev-parse --verify --quiet "$prev^{commit}" >/dev/null; then
        if [[ -n "$fetch_remote" ]]; then
            printf 'Fetching %s from %s...\n' "$prev" "$fetch_remote" >&2
            git fetch --no-tags "$fetch_remote" "$prev" 2>&1 || true
        fi
    fi
    if ! git rev-parse --verify --quiet "$prev^{commit}" >/dev/null; then
        local hint=""
        [[ -n "$fetch_remote" ]] \
            && hint=" (tried fetching from $fetch_remote)" \
            || hint="; no remote configured to fetch from"
        die "Commit $prev is not available locally$hint"
    fi

    local mb
    mb="$(git merge-base --all HEAD "$prev")" || die "Failed to compute merge-base"
    [[ -n "$mb" ]] || die "No merge-base found between HEAD and $prev"

    local prev_full
    prev_full="$(git rev-parse "$prev^{commit}")"
    [[ "$mb" != "$prev_full" ]] \
        || die "$prev is an ancestor of HEAD — nothing to range-diff. Provide an older PR tip from before a force-push, not a commit already in the current branch."

    if "$top_only"; then
        local top_base old_base top_count=""
        infer_top_base_commit || exit $?
        top_base="$_top_base_commit"
        top_count="${_explicit_top_count:-}"
        if [[ -n "$top_count" ]]; then
            printf 'Using PREV=%s TOP_BASE=%s TOP_N=%s\n' "$prev" "$top_base" "$top_count" >&2
            git range-diff "${prev}~${top_count}..${prev}" "${top_base}..HEAD" "${range_diff_args[@]}"
        else
            old_base="$(git merge-base "$prev" "$top_base")" || die "Failed to compute old stacked base"
            printf 'Using PREV=%s TOP_BASE=%s\n' "$prev" "$top_base" >&2
            git range-diff "${old_base}..${prev}" "${top_base}..HEAD" "${range_diff_args[@]}"
        fi
        return 0
    fi

    # If both tips are 2-parent merge commits and the old side balloons far
    # beyond the current PR width, compare the merged payload side directly.
    # This handles subtree-style PR branches that were rebased backwards onto
    # an older base, where mb..prev would otherwise include many unrelated
    # base-branch commits.
    if [[ -n "$n" ]] \
        && git rev-parse --verify --quiet HEAD^2 >/dev/null \
        && git rev-parse --verify --quiet "${prev}^2" >/dev/null \
        && ! git rev-parse --verify --quiet HEAD^3 >/dev/null \
        && ! git rev-parse --verify --quiet "${prev}^3" >/dev/null; then
        local old_span new_span prev_payload_count head_payload_count
        old_span="$(git rev-list --count "$mb..$prev")" || die "Failed to count commits on old side"
        new_span="$(git rev-list --count "$mb..HEAD")" || die "Failed to count commits on new side"
        prev_payload_count="$(git rev-list --count "${prev}^1..${prev}^2")" || die "Failed to count previous merge payload commits"
        head_payload_count="$(git rev-list --count "HEAD^1..HEAD^2")" || die "Failed to count current merge payload commits"

        if (( prev_payload_count > 0 && head_payload_count > 0 && old_span > n + prev_payload_count && new_span <= n + head_payload_count )); then
            printf 'Warning: PR appears to have been rebased onto an older commit; comparing merge payload only.\n' >&2
            printf 'Using PREV=%s MERGE_PAYLOAD=1\n' "$prev" >&2
            git range-diff "${prev}^1..${prev}^2" "HEAD^1..HEAD^2" "${range_diff_args[@]}"
            return 0
        fi
    fi

    # Use HEAD~n..HEAD for the new range to exclude any base-branch commits
    # that were incorporated when the PR was rebased. When n isn't provided
    # (--since mode), estimate it from the old range.
    [[ -n "$n" ]] || n="$(git rev-list --count "$mb..$prev")"

    printf 'Using PREV=%s N=%s\n' "$prev" "$n" >&2
    git range-diff "$mb...$prev" "HEAD~$n..HEAD" "${range_diff_args[@]}"
}

is_mainline_ref() {
    local refname="$1" short
    short="${refname##*/}"
    case "$short" in
        HEAD|master|main|trunk|develop|development|next|latest|31.x|32.x|33.x)
            return 0
            ;;
    esac
    return 1
}

infer_top_base_commit() {
    local explicit_base

    _top_base_commit=""
    if explicit_top_base_commit >/dev/null 2>/dev/null; then
        explicit_base="$_explicit_top_base"
    else
        explicit_base=""
    fi
    if "$debug"; then
        printf 'DEBUG explicit_top_base=%s\n' "${explicit_base:-<empty>}" >&2
    fi
    if [[ -n "$explicit_base" ]]; then
        _top_base_commit="$explicit_base"
        return 0
    fi

    local head current_branch push_ref upstream_ref push_commit="" upstream_commit="" push_remote="" range_base="" range_base_sha=""
    local -a candidates=()
    local refname commit distance best_commit=""
    local best_distance=-1

    head="$(git rev-parse HEAD)"
    current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    push_ref="$(git rev-parse --symbolic-full-name @{push} 2>/dev/null || true)"
    upstream_ref="$(git rev-parse --symbolic-full-name @{upstream} 2>/dev/null || true)"

    [[ -n "$push_ref" ]] && push_commit="$(git rev-parse "$push_ref")"
    if [[ -n "$push_ref" && "$push_ref" == refs/remotes/* ]]; then
        push_remote="${push_ref#refs/remotes/}"
        push_remote="${push_remote%%/*}"
    fi
    [[ -n "$upstream_ref" ]] && upstream_commit="$(git rev-parse "$upstream_ref")"
    range_base="$(top_range_base_ref 2>/dev/null || true)"
    [[ -n "$range_base" ]] && range_base_sha="$(git rev-parse "$range_base")"

    if [[ -n "$range_base_sha" ]]; then
        while read -r commit; do
            [[ -n "$commit" ]] || continue
            while read -r refname ref_commit; do
                [[ -n "$refname" && -n "$ref_commit" ]] || continue
                [[ "$refname" == "refs/remotes/"*"/HEAD" ]] && continue
                if [[ "$refname" == refs/remotes/* && -n "$push_remote" && "$refname" != refs/remotes/"$push_remote"/* ]]; then
                    continue
                fi
                [[ -n "$current_branch" && "$refname" == "refs/heads/$current_branch" ]] && continue
                [[ -n "$push_ref" && "$refname" == "$push_ref" ]] && continue
                [[ -n "$upstream_ref" && "$refname" == "$upstream_ref" ]] && continue
                is_mainline_ref "$refname" && continue
                [[ "$ref_commit" == "$head" ]] && continue
                [[ -n "$push_commit" && "$ref_commit" == "$push_commit" ]] && continue
                [[ -n "$upstream_commit" && "$ref_commit" == "$upstream_commit" ]] && continue
                ref_has_open_pr "$refname" || continue
                candidates+=("$ref_commit")
            done < <(git for-each-ref --format='%(refname) %(objectname)' --points-at "$commit" refs/heads refs/remotes)
        done < <(git rev-list --ancestry-path "${range_base_sha}..HEAD")
    else
        while read -r refname commit; do
            [[ -n "$refname" && -n "$commit" ]] || continue
            [[ "$refname" == "refs/remotes/"*"/HEAD" ]] && continue
            if [[ "$refname" == refs/remotes/* && -n "$push_remote" && "$refname" != refs/remotes/"$push_remote"/* ]]; then
                continue
            fi
            [[ -n "$current_branch" && "$refname" == "refs/heads/$current_branch" ]] && continue
            [[ -n "$push_ref" && "$refname" == "$push_ref" ]] && continue
            [[ -n "$upstream_ref" && "$refname" == "$upstream_ref" ]] && continue
            is_mainline_ref "$refname" && continue
            [[ "$commit" == "$head" ]] && continue
            [[ -n "$push_commit" && "$commit" == "$push_commit" ]] && continue
            [[ -n "$upstream_commit" && "$commit" == "$upstream_commit" ]] && continue
            ref_has_open_pr "$refname" || continue
            candidates+=("$commit")
        done < <(git for-each-ref --format='%(refname) %(objectname)' --merged HEAD refs/heads refs/remotes)
    fi

    if (( ${#candidates[@]} == 0 )); then
        die "Could not infer a stacked base for --top"
    fi

    while read -r commit; do
        [[ -n "$commit" ]] || continue
        distance="$(git rev-list --count "${commit}..HEAD")" || die "Failed to compute stacked distance"
        [[ "$distance" =~ ^[0-9]+$ ]] || die "Invalid stacked distance: $distance"
        (( distance > 0 )) || continue
        if (( best_distance < 0 || distance < best_distance )); then
            best_distance="$distance"
            best_commit="$commit"
        fi
    done < <(printf '%s\n' "${candidates[@]}" | sort -u)

    [[ -n "$best_commit" ]] || die "Could not infer a stacked base for --top"
    _top_base_commit="$best_commit"
}

# ---------------------------------------------------------------------------

if "$since_ack"; then
    # -------------------------------------------------------------------
    # --since-ack mode: range-diff from last ACK'd commit
    # -------------------------------------------------------------------

    tracking_ref="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true)"
    if [[ -z "$tracking_ref" && -n "$_inferred_tracking" ]]; then
        tracking_ref="$_inferred_tracking"
    fi
    [[ -n "$tracking_ref" ]] || die "No upstream ref configured for current branch"

    tracking_remote="${tracking_ref%%/*}"
    tracking_branch="${tracking_ref#*/}"

    url="$(git remote get-url "$tracking_remote" 2>/dev/null)" || die "Failed to get URL for remote $tracking_remote"
    owner="$(owner_from_url "$url")" || die "Failed to parse owner from remote URL"
    repo="$(repo_full_name_from_url "$url")" || die "Failed to parse repository from remote URL"

    resolve_pr "$owner" "$tracking_branch" "$repo"

    pr_json="$(view_resolved_pr "$pr_number" --json comments,reviews,commits,headRefOid,headRefName,headRepositoryOwner)" \
        || die "Failed to read PR metadata"

    # Verify local HEAD matches PR head
    pr_head="$(printf '%s\n' "$pr_json" | jq -r '.headRefOid // empty')"
    pr_head_ref="$(printf '%s\n' "$pr_json" | jq -r '.headRefName // empty')"
    pr_head_owner="$(printf '%s\n' "$pr_json" | jq -r '.headRepositoryOwner.login // empty')"
    local_head="$(git rev-parse --verify HEAD^{commit})"

    if [[ -n "$pr_head" && "$local_head" != "$pr_head" ]]; then
        stale_hint="git fetch --no-tags $tracking_remote $tracking_branch && git checkout $tracking_ref"
        die "Local HEAD $local_head does not match PR head $pr_head. Update first (e.g. $stale_hint)."
    fi

    # Find last ACK/utACK hash from PR comments and reviews
    prev="$(
        printf '%s\n' "$pr_json" | jq -r --arg login "$login" '
            def normalize_time:
                (.submittedAt // .updatedAt // .createdAt // "");

            def entry:
                {
                    at: normalize_time,
                    body: (.body // ""),
                    author: (.author.login // "")
                };

            [
                (.comments[]? | entry),
                (.reviews[]?  | entry)
            ]
            | map(select(.author == $login))
            | map(
                . + {
                    ack_sha: (try (.body | capture("(?i)(?:^|[^[:alnum:]_])(?:ut)?ack\\b[^0-9a-fA-F]*?(?<sha>[0-9a-fA-F]{7,40})\\b").sha) catch null)
                }
            )
            | map(select(.ack_sha != null))
            | sort_by(.at)
            | last
            | .ack_sha // empty
        '
    )" || die "Failed to parse ACK hash from PR metadata"

    [[ -n "$prev" ]] || die "No ACK comment found for this PR. Have you ACK'd it yet?"

    n="$(printf '%s\n' "$pr_json" | jq -r '.commits | length')"
    [[ "$n" =~ ^[0-9]+$ ]] || die "Invalid PR commit count: $n"
    (( n > 0 )) || die "PR commit count is zero"

    run_from_prev "$prev" "$n" "$tracking_remote"

elif [[ -n "$since_hash" ]]; then
    # -------------------------------------------------------------------
    # --since mode: range-diff from a caller-specified commit
    # -------------------------------------------------------------------

    tracking_ref="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true)"
    if [[ -z "$tracking_ref" && -n "$_inferred_tracking" ]]; then
        tracking_ref="$_inferred_tracking"
    fi
    tracking_remote="${tracking_ref%%/*}"

    run_from_prev "$since_hash" "" "$tracking_remote"

else
    # -------------------------------------------------------------------
    # Default mode: range-diff local HEAD vs pushed remote ref
    # -------------------------------------------------------------------

    if ! prev="$(git rev-parse --verify @{push} 2>/dev/null)"; then
        upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true)"
        upstream_remote="${upstream%%/*}"
        login="$(gh api user --jq .login 2>/dev/null || true)"
        if [[ -n "$upstream_remote" && -n "$login" && "$upstream_remote" != "$login" ]]; then
            die "No push ref configured for current branch (@{push}). This looks like someone else's PR — did you mean:"$'\n'"  git range-diff-remote --since-ack"
        fi
        if [[ -n "$_inferred_tracking" ]]; then
            suggested="${_inferred_tracking#*/}"
            die "Detached HEAD; did you mean:"$'\n'"  git checkout $suggested"
        fi
        die "No push ref configured for current branch (@{push})"
    fi

    push_ref="$(git rev-parse --symbolic-full-name @{push})"
    push_remote="${push_ref#refs/remotes/}"
    push_remote="${push_remote%%/*}"
    push_branch="${push_ref#refs/remotes/$push_remote/}"

    if [[ "$prev" == "$(git rev-parse HEAD)" ]]; then
        current_branch="$(git rev-parse --abbrev-ref HEAD)"
        push_short="$(git rev-parse --abbrev-ref @{push})"
        printf 'On branch %s\n' "$current_branch"
        printf "Your branch is up to date with '%s'.\n" "$push_short"
        exit 0
    fi

    url="$(git remote get-url --push "$push_remote" 2>/dev/null || git remote get-url "$push_remote")" \
        || die "Failed to get URL for remote $push_remote"
    owner="$(owner_from_url "$url")" || die "Failed to parse owner from remote URL"
    repo="$(repo_full_name_from_url "$url")" || die "Failed to parse repository from remote URL"

    resolve_pr "$owner" "$push_branch" "$repo"

    pr_view="$(view_resolved_pr "$pr_number" --json commits,baseRefName)" \
        || die "Failed to read PR metadata"

    if "$top_only"; then
        infer_top_base_commit || exit $?
        top_base="$_top_base_commit"
        if [[ -n "${_explicit_top_count:-}" ]]; then
            printf 'Using PUSH=%s TOP_BASE=%s TOP_N=%s\n' "$prev" "$top_base" "$_explicit_top_count" >&2
            git range-diff "${prev}~${_explicit_top_count}..${prev}" "${top_base}..HEAD" --creation-factor=95 "${range_diff_args[@]}"
        else
            remote_top_base="$(git merge-base "$prev" "$top_base")" || die "Failed to compute remote stacked base"
            printf 'Using PUSH=%s TOP_BASE=%s\n' "$prev" "$top_base" >&2
            git range-diff "${remote_top_base}..${prev}" "${top_base}..HEAD" --creation-factor=95 "${range_diff_args[@]}"
        fi
    else
        n_remote="$(printf '%s\n' "$pr_view" | jq -r '.commits | length')"
        base_branch="$(printf '%s\n' "$pr_view" | jq -r '.baseRefName')"
        base_ref="$(base_ref_for_branch "$base_branch" "$push_remote" 2>/dev/null || true)"
        [[ -n "$base_ref" ]] || die "Could not find local ref for base branch $base_branch"
        n_local="$(git rev-list --count "${base_ref}..HEAD")"

        git range-diff "${prev}~${n_remote}..${prev}" "HEAD~${n_local}..HEAD" --creation-factor=95 "${range_diff_args[@]}"
    fi
fi
